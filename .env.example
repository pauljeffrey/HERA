# AI Model Configuration
# MODEL_API_KEY is the primary key. For OpenRouter slugs (e.g. meta-llama/…:free),
# set this to your OpenRouter API key. Provider-specific fallbacks:
# OPENAI_API_KEY (gpt-*), GOOGLE_API_KEY (gemini-*), OPENROUTER_API_KEY (unknown slugs).
MODEL_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
MODEL_NAME=meta-llama/llama-3.3-70b-instruct:free
DEBUG=True

# Logging — stdout + rotating file at backend/app/data/logs/hera.log
HERA_LOG_LEVEL=INFO

# Database: supabase (default, HTTPS REST API) | local (Docker Postgres)
DATABASE_MODE=supabase
PREPOPULATE_DB=if_empty

# Supabase REST API — used when DATABASE_MODE=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your_service_role_key
SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Supabase direct Postgres — used by FTS/raw-SQL tools (services/clinical,
# services/funnel). Use the Supavisor pooler host, not db.<ref>.supabase.co
# directly — that host is IPv6-only and unreachable from most container
# networks (Docker Desktop, many PaaS hosts).
SUPABASE_DB_HOST=aws-0-us-east-1.pooler.supabase.com
SUPABASE_DB_HOSTADDR=
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.your-project-ref
SUPABASE_DB_PASSWORD=

# Local Postgres — used when DATABASE_MODE=local
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5433
LOCAL_DB_USER=hera
LOCAL_DB_PASSWORD=hera
LOCAL_DB_NAME=hera

# Redis — chat history, agent traces, and task/pipeline intermediate state.
# Either set REDIS_URL directly, or set REDIS_SERVER_HOST/PORT/PASSWORD (e.g.
# for an existing Dokploy-managed Redis service) and it's built for you —
# see app/config.py::_build_redis_url. REDIS_URL wins if both are set.
REDIS_URL=redis://localhost:6379/0
REDIS_SERVER_HOST=
REDIS_SERVER_PORT=6379
REDIS_PASSWORD=
REDIS_CHAT_TTL_SECONDS=86400
REDIS_TASK_TTL_SECONDS=259200

# Matching funnel — cap retrieval and Tier 3 LLM evaluation
FTS_TOP_K=10
SEMANTIC_TOP_K=10
TIER3_PATIENT_CAP=20
# VS_MIN_SIMILARITY / VS_MERGE_SCORE_THRESHOLD — optional; defaults follow VECTOR_BACKEND
# (pinecone: 0.35 / 0.42, pgvector: 0.72 / 0.90)
PATIENT_TRAJECTORIES_PATH=
SOAP_NOTES_PATH=
SOAP_OUTPUT_DIR=
BATCH_MAX_ENQUEUED_TOKENS=

# Vector backend: pinecone (default, integrated hosted embeddings — no local
# model download, both ingestion and query embed server-side) | pgvector
# (local sentence-transformers embedding model)
VECTOR_BACKEND=pinecone
PINECONE_API_KEY=
PINECONE_INDEX=hera
PINECONE_INDEX_HOST=
PINECONE_NAMESPACE=clinical-notes
PINECONE_MODEL=multilingual-e5-large
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Tier 3 eligibility evaluation engine: api (default, cloud model via
# MODEL_NAME/MODEL_API_KEY) | modal (self-hosted vLLM behind an
# OpenAI-compatible endpoint — see backend/app/workers/README.md)
HERA_TIER3_ENGINE=api
MODAL_VLLM_BASE_URL=
MODAL_VLLM_API_KEY=not-needed
MODAL_VLLM_MODEL=google/gemma-3-4b-it
